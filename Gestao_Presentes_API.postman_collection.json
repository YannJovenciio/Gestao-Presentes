            "url": {
              "raw": "http://localhost:8080/api/presente",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "presente"]
            },
            "description": "Busca os presentes associados ao usuário autenticado"
          },
          "response": []
        },
        {
          "name": "Criar Presente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "Token JWT obtido no login"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
